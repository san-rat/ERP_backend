@OrderService_HostAddress = http://localhost:5003
@erpToken = YOUR_ERP_JWT_TOKEN_HERE
@internalServiceKey = local-dev-internal-service-key

### Health
GET {{OrderService_HostAddress}}/health

### Get all orders
GET {{OrderService_HostAddress}}/api/orders
Authorization: Bearer {{erpToken}}

### Get order by id
GET {{OrderService_HostAddress}}/api/orders/00000000-0000-0000-0000-000000000000
Authorization: Bearer {{erpToken}}

### Create order
POST {{OrderService_HostAddress}}/api/orders
Content-Type: application/json
Authorization: Bearer {{erpToken}}

{
  "externalOrderId": "ECOM-1001",
  "customerId": "00000000-0000-0000-0000-000000000000",
  "totalAmount": 2500.00
}

### Update order status
PUT {{OrderService_HostAddress}}/api/orders/00000000-0000-0000-0000-000000000000/status
Content-Type: application/json
Authorization: Bearer {{erpToken}}

{
  "requestedStatus": "Cancelled",
  "cancellationReason": "Customer requested cancellation"
}

### Manager report
GET {{OrderService_HostAddress}}/api/orders/reports/summary
Authorization: Bearer {{erpToken}}

### Internal ecommerce order creation
POST {{OrderService_HostAddress}}/api/internal/orders/ecommerce
Content-Type: application/json
X-Internal-Service-Key: {{internalServiceKey}}

{
  "customerId": "00000000-0000-0000-0000-000000000000",
  "externalOrderId": "ECOM-20260418-001",
  "paymentMethod": "CARD",
  "shippingAddressSnapshot": {
    "fullName": "Jamie Customer",
    "phone": "+94-77-555-0101",
    "addressLine1": "15 Galle Road",
    "city": "Colombo",
    "postalCode": "00300",
    "country": "Sri Lanka"
  },
  "items": [
    {
      "productId": "00000000-0000-0000-0000-000000000000",
      "quantity": 2
    }
  ]
}
